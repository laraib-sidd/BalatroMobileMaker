<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BalatroMobile.Gui.ViewModels"
             x:Class="BalatroMobile.Gui.Views.ModManagerView"
             x:DataType="vm:ModManagerViewModel">

  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Spacing="16" Margin="0,0,0,16">
      <TextBlock Text="&#x1F9E9; Mod Manager" FontSize="24" FontWeight="Bold"
                 Foreground="{StaticResource BalatroTextPrimaryBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="balatro-secondary" Command="{Binding SelectAllCommand}" Content="Select All" />
        <Button Classes="balatro-secondary" Command="{Binding DeselectAllCommand}" Content="Deselect All" />
        <Button Classes="balatro-secondary" Command="{Binding RefreshCommand}" Content="&#x1F504; Refresh" />
      </StackPanel>
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding Summary}" Classes="caption" Margin="0,16,0,0" />

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Mods}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ModEntry">
            <Border Classes="balatro-card" Margin="0,4">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                          IsEnabled="{Binding !IsRequired}" Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" FontSize="14"
                             Foreground="{StaticResource BalatroTextPrimaryBrush}" />
                  <TextBlock Text="Required for mobile compatibility" Classes="caption"
                             IsVisible="{Binding IsRequired}" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" Classes="caption"
                           VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
